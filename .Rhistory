anti_elitism = v2paanteli,
people_centrism = v2papeople,
political_pluralism = v2paplur,
respect_opponents = v2paopresp,
minority_rights = v2paminor,
gender_equality = v2pagender
) %>%
filter(!is.na(anti_pluralism) & !is.na(populism))
###  Populism trend for India over time
vparty_subset %>%
filter(country_name == "India") %>%
ggplot(aes(x = year, y = populism, color = party_name)) +
geom_line(size = 1.2) +
labs(title = "Populism Trend in Indian Political Parties Over Time",
x = "Year", y = "Populism Score") +
theme_minimal()
vparty_subset <- vparty_subset %>%
mutate(party_name = case_when(
party_name == "Indian National Congress (Organisation)" ~ "Indian National Congress",
party_name == "Indian People's Party" ~ "Indian People's Party (BJP)",
TRUE ~ party_name
))
latest_year <- max(vparty_subset$year, na.rm = TRUE)
vparty_subset %>%
filter(year == latest_year) %>%
group_by(country_name) %>%
summarize(avg_antiplural = mean(anti_pluralism, na.rm = TRUE)) %>%
arrange(desc(avg_antiplural)) %>%
slice_max(avg_antiplural, n = 15) %>%
ggplot(aes(x = reorder(country_name, avg_antiplural), y = avg_antiplural)) +
geom_col(fill = "firebrick") +
coord_flip() +
labs(
title = paste("Top 15 Countries by Average Anti-Pluralism (", latest_year, ")", sep = ""),
x = "Country",
y = "Average Anti-Pluralism Score"
) +
theme_minimal()
vparty_subset %>%
filter(!is.na(populism) & !is.na(political_pluralism)) %>%
ggplot(aes(x = populism, y = political_pluralism)) +
geom_point(alpha = 0.6, color = "darkblue") +
geom_smooth(method = "lm", se = FALSE, color = "red", linetype = "dashed") +
labs(
title = "Populism vs. Political Pluralism Across Parties",
x = "Populism Score",
y = "Political Pluralism Score"
) +
theme_minimal()
## Research Question based on the graphs presented
##
# 1. Are populist parties more likely to reject minority rights and pluralistic values, even in democracies?
# Dependent variables: minority_rights, political_pluralism
#
# Independent variable: populism
# 2. Do parties with high populism and anti-elitism scores show significantly lower respect for political opponents?
# DV: respect_opponents
#
# IVs: populism, anti_elitism
model_df <- vparty_subset %>%
select(
country_name, year, party_name,
populism,
minority_rights,
political_pluralism,
anti_elitism,
respect_opponents
) %>%
filter(
!is.na(populism),
!is.na(minority_rights),
!is.na(political_pluralism),
!is.na(anti_elitism),
!is.na(respect_opponents)
)
summary(model_df)
# Model 1: Populism ➝ Minority Rights
lm1 <- lm(minority_rights ~ populism, data = model_df)
summary(lm1)
# Model 2: Populism ➝ Political Pluralism
lm2 <- lm(political_pluralism ~ populism, data = model_df)
summary(lm2)
# LM3: Populism + Anti-Elitism ➝ Respect for Opponents
lm3 <- lm(respect_opponents ~ populism + anti_elitism, data = model_df)
summary(lm3)
library(rstanarm)
# Populism ➝ Minority Rights
bayes_m1 <- stan_glm(minority_rights ~ populism, data = model_df, refresh = 0)
#Populism ➝ Political Pluralism
bayes_m2 <- stan_glm(political_pluralism ~ populism, data = model_df, refresh = 0)
summary(bayes_m1)
summary(bayes_m2)
#  Populism + Anti-Elitism ➝ Respect for Opponents
bayes_m3 <- stan_glm(respect_opponents ~ populism + anti_elitism, data = model_df, refresh = 0)
summary(bayes_m3)
# Visualizing relationship between Populism and Respect for Opponents
ggplot(model_df, aes(x = populism, y = respect_opponents)) +
geom_point(alpha = 0.5, color = "darkgreen") +
geom_smooth(method = "lm", se = FALSE, color = "black", linetype = "dashed") +
labs(
title = "Populism vs. Respect for Political Opponents",
x = "Populism Score",
y = "Respect for Opponents Score"
) +
theme_minimal()
# Plotting Anti-Elitism vs. Respect for Political Opponents
ggplot(model_df, aes(x = anti_elitism, y = respect_opponents)) +
geom_point(alpha = 0.5, color = "purple") +
geom_smooth(method = "lm", se = FALSE, color = "black", linetype = "dashed") +
labs(
title = "Anti-Elitism vs. Respect for Political Opponents",
x = "Anti-Elitism Score",
y = "Respect for Opponents Score"
) +
theme_minimal()
knitr::opts_chunk$set(echo = TRUE)
lm4 <- lm(gender_equality ~ populism, data = model_df)
knitr::opts_chunk$set(echo = TRUE)
